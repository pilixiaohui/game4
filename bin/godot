#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd -- "$SCRIPT_DIR/.." && pwd)"
LOCAL_GODOT_BIN="$ROOT_DIR/tools/godot/Godot_v4.7-stable_linux.x86_64"

export XDG_DATA_HOME="${XDG_DATA_HOME:-$ROOT_DIR/.godot-home/share}"
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$ROOT_DIR/.godot-home/config}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$ROOT_DIR/.godot-home/cache}"

mkdir -p "$XDG_DATA_HOME" "$XDG_CONFIG_HOME" "$XDG_CACHE_HOME"

if [ -n "${GODOT_BIN:-}" ]; then
	if [ -x "$GODOT_BIN" ]; then
		exec "$GODOT_BIN" "$@"
	fi
	echo "GODOT_BIN is set but is not executable: $GODOT_BIN" >&2
	exit 127
fi

if [ -x "$LOCAL_GODOT_BIN" ]; then
	exec "$LOCAL_GODOT_BIN" "$@"
fi

if command -v godot4 >/dev/null 2>&1; then
	exec godot4 "$@"
fi

if command -v godot >/dev/null 2>&1; then
	exec godot "$@"
fi

echo "Godot executable not found." >&2
echo "Set GODOT_BIN, place Godot_v4.7-stable_linux.x86_64 in tools/godot/, or install godot4/godot on PATH." >&2
exit 127
